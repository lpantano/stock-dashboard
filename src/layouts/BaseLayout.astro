---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "S&P 500 Year-by-Year Historical Charts 2021–2026 | Stock Dashboard",
  description = "Free interactive S&P 500 historical charts for every year from 2021 to 2026. See daily closing prices, annual returns, and year-over-year performance at a glance.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-preview.png", Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "S&P 500 Historical Daily Prices 2021–2026",
  description:
    "Daily closing prices for the S&P 500 index from 2021 through 2026, updated weekly.",
  url: canonicalURL.toString(),
  temporalCoverage: "2021/..",
  variableMeasured: [
    { "@type": "PropertyValue", name: "S&P 500 Close", unitCode: "USD" },
  ],
  publisher: { "@type": "Organization", name: "S&P 500 Dashboard" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta property="og:url" content={canonicalURL.toString()} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* ─── Surfaces ─────────────────────────────── */
        --bg:               #f4f5f7;   /* Warm off-white page ground */
        --surface:          #ffffff;   /* Pure white cards */
        --surface-elevated: #ffffff;   /* Tooltips (elevated by shadow) */
        --surface-subtle:   #f0f1f4;   /* Inset chart area */

        /* ─── Borders ──────────────────────────────── */
        --border:           #e2e4ea;   /* Card edges */
        --border-subtle:    #eceef2;   /* Internal dividers */
        --border-active:    #1d3ecf;   /* Focus / selection rings */

        /* ─── Text ─────────────────────────────────── */
        --text:             #14151a;   /* Near-black primary */
        --muted-strong:     #555870;   /* Secondary data labels */
        --muted:            #8f92a8;   /* Captions, axis ticks */

        /* ─── Accent (Navy Blue) ─────────────────────── */
        --accent:           #2756e8;   /* Chart lines, active states */
        --accent-bright:    #1d3ecf;   /* Hover text, active button text */
        --accent-dim:       #dce6ff;   /* Active button fill (light blue tint) */

        /* ─── Semantic ───────────────────────────────── */
        --green:            #12a05c;   /* Positive returns */
        --green-dim:        #e3f7ed;   /* Positive fills */
        --red:              #d93636;   /* Negative returns */
        --red-dim:          #fce9e9;   /* Negative fills */

        /* ─── Shadows ───────────────────────────────── */
        --shadow-sm:  0 1px 3px rgba(20,21,26,0.07), 0 0 0 1px rgba(20,21,26,0.04);
        --shadow-md:  0 1px 3px rgba(20,21,26,0.06), 0 4px 16px rgba(20,21,26,0.08), 0 0 0 1px rgba(20,21,26,0.04);
        --shadow-lg:  0 8px 32px rgba(20,21,26,0.12), 0 2px 8px rgba(20,21,26,0.08), 0 0 0 1px rgba(39,86,232,0.12);

        /* ─── Motion ────────────────────────────────── */
        --ease-out:      cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --ease-spring:   cubic-bezier(0.34, 1.20, 0.64, 1.00);
        --duration-fast: 150ms;
        --duration-base: 200ms;

        /* ─── Radius ────────────────────────────────── */
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 12px;

        /* ─── Typography ────────────────────────────── */
        --font-display: 'Syne', system-ui, sans-serif;
        --font-mono:    'DM Mono', 'Courier New', monospace;

        /* Legacy aliases for compatibility */
        --font-head: var(--font-display);
      }

      html {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-mono);
        display: flex;
        justify-content: center;
      }

      body {
        width: 100%;
        max-width: 1100px;
        padding: 2rem 1.25rem 4rem;
      }

      a { color: var(--accent); }

      .view-toggle {
        display: flex;
        justify-content: center;
        margin-bottom: 1.5rem;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
